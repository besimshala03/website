<section id="about" class="max-w-5xl mx-auto px-6 pt-8 pb-16 fade-up">
  <div class="border-t border-border pt-10">
    <div class="grid grid-cols-1 md:grid-cols-[160px_1fr] gap-8 md:gap-16">
      <!-- Label column -->
      <div>
        <span class="text-xs text-muted uppercase tracking-widest">about</span>
      </div>

      <!-- Content column -->
      <div class="space-y-6">
        <p class="text-sm text-primary leading-relaxed">
          AI &amp; Data Automation analyst at Amazon Munich, currently pursuing a M.Sc. in Information Systems at TU Munich.
        </p>
        <p class="text-sm text-muted leading-relaxed">
          Previously AI engineer at BMW Group. Combining engineering depth with business thinking.
        </p>

        <!-- Quick facts row -->
        <div class="flex flex-wrap gap-x-8 gap-y-3 pt-2 border-t border-border">
          <div>
            <p class="text-xs text-muted mb-0.5">location</p>
            <p class="text-xs text-primary">Munich, Germany</p>
          </div>
          <div>
            <p class="text-xs text-muted mb-0.5">currently</p>
            <p class="text-xs text-primary">Amazon Munich · TU Munich</p>
          </div>
          <div>
            <p class="text-xs text-muted mb-0.5">focus</p>
            <p class="text-xs text-primary">LLMs · Cloud · Automation</p>
          </div>
          <div>
            <p class="text-xs text-muted mb-0.5">languages</p>
            <p class="text-xs text-primary">German (Native) · Albanian (Native) · English (C1)</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
