---
const work = [
  {
    org: 'Amazon Munich',
    role: 'Working Student, AI & Data Automation',
    period: 'Apr 2026–present',
    note: '',
  },
  {
    org: 'BMW Group',
    role: 'Working Student, Applied AI Engineer',
    period: 'Feb 2025–Feb 2026',
    note: '',
  },
  {
    org: 'BMW Group',
    role: 'Software & Cloud Engineer Intern',
    period: 'Sep 2024–Jan 2025',
    note: '',
  },
  {
    org: 'Lösch & Partner GmbH',
    suborg: 'Extern for BMW Group',
    role: 'Working Student, Software Developer',
    period: 'Jan 2024–Aug 2024',
    note: '',
  },
  {
    org: 'metafinanz',
    suborg: 'Allianz Group subsidiary',
    role: 'Working Student, Business Analyst',
    period: 'Jan 2023–Dec 2023',
    note: '',
  },
];

const academic = [
  {
    org: 'TU Munich',
    role: 'M.Sc. Information Systems',
    period: 'Apr 2026–Apr 2028',
    note: '',
  },
  {
    org: 'HM Munich',
    role: 'B.Sc. Business Informatics - Information Technology',
    period: 'Oct 2022–Mar 2026',
    note: 'Thesis: 1.0',
  },
];
---
<section id="work" class="max-w-5xl mx-auto px-6 pt-10 pb-10 fade-up">
  <h2 class="text-xs text-muted uppercase tracking-widest mb-10">experience</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-8">

    <!-- Work -->
    <div>
      <p class="text-xs text-muted uppercase tracking-widest mb-6 pb-3 border-b border-border">work</p>
      <div class="relative pl-5">
        <div class="absolute left-0 top-0 bottom-0 w-px bg-border"></div>
        <div class="space-y-7">
          {work.map(entry => (
            <div class="relative">
              <div class="timeline-dot absolute -left-[22px]"></div>
              <div class="pl-2">
                <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5 mb-1">
                  <span class="text-sm font-medium text-primary">{entry.org}</span>
                  <span class="text-xs text-muted">· {entry.period}</span>
                </div>
                {'suborg' in entry && <p class="text-xs text-muted opacity-70 mb-0.5">{(entry as any).suborg}</p>}
                <p class="text-xs text-muted">{entry.role}</p>
                {entry.note && <p class="text-xs text-muted opacity-60 mt-0.5">{entry.note}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Academic -->
    <div>
      <p class="text-xs text-muted uppercase tracking-widest mb-6 pb-3 border-b border-border">education</p>
      <div class="relative pl-5">
        <div class="absolute left-0 top-0 bottom-0 w-px bg-border"></div>
        <div class="space-y-7">
          {academic.map(entry => (
            <div class="relative">
              <div class="timeline-dot absolute -left-[22px]"></div>
              <div class="pl-2">
                <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5 mb-1">
                  <span class="text-sm font-medium text-primary">{entry.org}</span>
                  <span class="text-xs text-muted">·</span>
                  <span class="text-xs text-muted">{entry.period}</span>
                </div>
                <p class="text-xs text-muted">{entry.role}</p>
                {entry.note && <p class="text-xs text-muted opacity-60 mt-0.5">{entry.note}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>
